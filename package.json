{
  "name": "codex-web-bridge",
  "version": "1.1.13",
  "private": true,
  "description": "Pagina web para crear carpetas, abrir VS Code y chatear con Contexto",
  "scripts": {
    "start": "node server.js",
    "build:pages": "node scripts/build-pages.js",
    "setup:github": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-github-repo.ps1",
    "start:pages-backend": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-pages-backend.ps1",
    "start:public-backend": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-public-backend.ps1"
  }
}
