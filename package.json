{
  "name": "codex-web-bridge",
  "version": "1.3.0",
  "private": true,
  "description": "Pagina web para crear carpetas, abrir VS Code y chatear con Contexto",
  "scripts": {
    "start": "node server.js",
    "build:pages": "node scripts/build-pages.js",
    "generate:uni-labs": "node scripts/generate-uni-lab-batch.js",
    "setup:github": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-github-repo.ps1",
    "start:pages-backend": "node scripts/start-managed-runtime.js pages",
    "start:public-backend": "node scripts/start-managed-runtime.js public",
    "start:permanent-backend": "node scripts/start-managed-runtime.js permanent",
    "stop:managed-runtime": "node scripts/stop-managed-runtime.js",
    "status:managed-runtime": "node scripts/status-managed-runtime.js"
  },
  "dependencies": {
    "mammoth": "^1.11.0"
  }
}
